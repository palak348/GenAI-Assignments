# Get a free Gemini API key (no credit card): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant Cloud free tier (1 GB, no credit card): https://cloud.qdrant.io/
# For local Qdrant, set QDRANT_URL=http://localhost:6333 and leave QDRANT_API_KEY empty.
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
